{
  "$schema": "../node_modules/@agentic-workflow-kit/eval-kit/schemas/eval-kit.config.schema.json",
  "schema_version": "eval-kit.config.v1",
  "suite_id": "design-to-plan",
  "suite_root": ".",
  "results_root": "results",
  "adapter": "adapter.mjs",
  "cases": {
    "root": "cases",
    "include": [
      "case-projection-graph-evidence-v1",
      "case-review-plan-blockers-v1"
    ]
  },
  "prompt_templates": {
    "pointwise_judge": "judges/pointwise.prompt.md"
  },
  "methods": {
    "deterministic": {
      "enabled": true,
      "grader": "bootstrap-placeholder",
      "reporter": "bootstrap-markdown"
    },
    "generate": {
      "enabled": false
    },
    "judge_coverage": {
      "enabled": true
    },
    "judge_pairwise": {
      "enabled": false
    },
    "report": {
      "enabled": false
    }
  }
}
